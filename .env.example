# UHT Factory API
UHT_API_BASE_URL=https://factory.universalhex.org/api/v1
UHT_API_TIMEOUT=30
UHT_CACHE_TTL=3600

# Neo4j Database
UHT_NEO4J_URI=bolt://localhost:7687
UHT_NEO4J_USER=neo4j
UHT_NEO4J_PASSWORD=uhtsubstrate123
UHT_NEO4J_DATABASE=neo4j

# Reasoning Configuration
UHT_CONFIDENCE_THRESHOLD=0.7
UHT_MAX_INFERENCE_DEPTH=3
UHT_CONTEXT_RELEVANCE_WINDOW_HOURS=168

# MCP Server
UHT_SERVER_NAME=UHT Substrate Agent
UHT_SERVER_HOST=localhost
UHT_SERVER_PORT=8765

# Logging
UHT_LOG_LEVEL=INFO
